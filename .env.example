APP_NAME=PayXora
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=payxora
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

#--------------------------------------------------------------------------
# PayXora — Configuration Paiement
#--------------------------------------------------------------------------

# Commission
PAYXORA_COMMISSION_RATE=3.0
PAYXORA_COMMISSION_MIN=100
PAYXORA_COMMISSION_MAX=50000

# Delais
PAYXORA_DISPUTE_HOURS=48
PAYXORA_TRANSACTION_EXPIRY_HOURS=72

# Provider par defaut (laisser vide en dev pour utiliser 'fake')
PAYXORA_DEFAULT_PROVIDER=

#--------------------------------------------------------------------------
# TMoney (Togocel)
#--------------------------------------------------------------------------
TMONEY_API_URL=https://api.tmoney.tg/v1
TMONEY_API_KEY=
TMONEY_API_SECRET=
TMONEY_SANDBOX=true

#--------------------------------------------------------------------------
# Moov Money (Moov Africa Togo)
#--------------------------------------------------------------------------
MOOV_API_URL=https://api.moovmoney.tg/v1
MOOV_API_KEY=
MOOV_API_SECRET=
MOOV_SANDBOX=true

#--------------------------------------------------------------------------
# Carte Bancaire (Stripe / Flutterwave / CinetPay / PayDunya)
#--------------------------------------------------------------------------
# Provider actif : stripe, flutterwave, cinetpay, paydunya
CARD_PROVIDER=stripe
CARD_API_KEY=
CARD_API_SECRET=
CARD_WEBHOOK_SECRET=
CARD_SANDBOX=true

#--------------------------------------------------------------------------
# Fake Mobile Money (DEV UNIQUEMENT — ne jamais activer en prod)
#--------------------------------------------------------------------------
FAKE_PAYMENT_ENABLED=true

#--------------------------------------------------------------------------
# Brevo (Emails transactionnels)
#--------------------------------------------------------------------------
BREVO_API_KEY=
BREVO_FROM_EMAIL=noreply@payxora.tg
BREVO_FROM_NAME="PayXora"

#--------------------------------------------------------------------------
# KYC
#--------------------------------------------------------------------------
KYC_REQUIRED=true
KYC_AUTO_APPROVE=false

#--------------------------------------------------------------------------
# Laravel defaults
#--------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
